// FocusForge data model — Epic 1 (pm/user_stories.md FF-1/FF-2/FF-3).
//
// Aggregate boundaries (see services/api/architecture/aggregates.md):
//   - StudySession is its own aggregate root. It references SubSkill only —
//     Skill is reached via `subSkill.skill`, deliberately NOT duplicated
//     onto StudySession (see sa-adr-001). That removes an entire class of
//     "subSkill belongs to a different skill than the stored skillId"
//     invariant bugs by construction.
//   - PlannedTarget is a separate aggregate root, scoped at the Skill level
//     (not SubSkill — FF-16 sets targets per skill, not per sub-skill).
//   - Skill / SubSkill are reference data (seeded), not aggregates: no
//     lifecycle, no invariants beyond referential integrity.
//
// Business-rule invariants (durationMinutes > 0, occurredAt not in the
// future, weekStartDate normalized to Monday) are enforced at the
// application layer before writes, not as DB CHECK constraints — see
// services/api/architecture/persistence_patterns.md for why.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Skill {
  id        Int      @id @default(autoincrement())
  /// Matches the frontend design tokens 1:1 (bg-domain-<slug> in
  /// apps/web/src/styles/tokens.css) — "quant" | "ielts" | "js" | "stats" | "dl".
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())

  subSkills      SubSkill[]
  plannedTargets PlannedTarget[]
}

model SubSkill {
  id        Int      @id @default(autoincrement())
  skillId   Int
  skill     Skill    @relation(fields: [skillId], references: [id])
  slug      String
  name      String
  createdAt DateTime @default(now())

  studySessions StudySession[]

  @@unique([skillId, slug])
}

model StudySession {
  id         Int      @id @default(autoincrement())
  subSkillId Int
  subSkill   SubSkill @relation(fields: [subSkillId], references: [id])

  durationMinutes Int
  /// Date only (no time-of-day) — a session belongs to a day, not a
  /// timestamp. Stored as SQL DATE to avoid timezone drift on the day
  /// value, which the FF-2 round-trip acceptance criterion depends on.
  occurredAt      DateTime @db.Date
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Supports Epic 3's rolling week/month aggregation (group by subSkill,
  // filter by occurredAt range) and Epic 2's history view (list by date).
  @@index([occurredAt])
  @@index([subSkillId])
}

model PlannedTarget {
  id      Int   @id @default(autoincrement())
  skillId Int
  skill   Skill @relation(fields: [skillId], references: [id])

  /// Always the Monday of the target week (application-normalized) — see
  /// persistence_patterns.md. Makes the uniqueness constraint below
  /// actually mean "one target per skill per week."
  weekStartDate DateTime @db.Date
  targetMinutes Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([skillId, weekStartDate])
}

/// LLM-guided planning (extends Epic 4 with an AI-assisted entry point —
/// the learner states a goal, gets 3 candidate weekly-hour plans back, and
/// picking one materializes as ordinary PlannedTarget rows across the
/// goal's timeframe). Goal/GoalPlanOption are reference-ish records of a
/// planning session, not aggregates: no invariants beyond the one-selected-
/// option constraint below, enforced at the application layer (see
/// goal-plan.rules.ts) the same way PlannedTarget's normalization is.
model Goal {
  id            Int      @id @default(autoincrement())
  /// Free text — "Complete GRE and IELTS in 3 months" — not constrained to
  /// existing Skill names; the LLM plan may reference categories that get
  /// created on selection (see goals.service.ts).
  description   String
  durationWeeks Int
  /// Optional current mock-test scores, e.g. [{"label":"GRE","score":"310"}].
  /// Free-form per exam since scoring scales differ (GRE 260-340, IELTS
  /// 0-9 bands) — not worth a typed schema for a handful of display strings.
  currentScores Json?
  /// Existing Skill ids the learner explicitly picked to target, so the LLM
  /// prompt can require those exact names verbatim instead of hoping its
  /// own free-text-derived guess matches an existing Skill by name (see
  /// goals.service.ts resolveOrCreateSkill's case-insensitive lookup).
  /// Categories the goal implies beyond this list are still inferred by
  /// the model from `description` and created fresh on selection.
  targetSkillIds Int[]    @default([])
  createdAt      DateTime @default(now())
  /// Set when a plan option is selected and its PlannedTargets are created.
  appliedAt     DateTime?

  planOptions          GoalPlanOption[] @relation("GoalOptions")
  selectedPlanOptionId Int?             @unique
  selectedPlanOption   GoalPlanOption?  @relation("SelectedPlan", fields: [selectedPlanOptionId], references: [id])
}

model GoalPlanOption {
  id     Int  @id @default(autoincrement())
  goalId Int
  goal   Goal @relation("GoalOptions", fields: [goalId], references: [id])

  /// 40 / 30 / 20 — the three candidate weekly commitments generated per goal.
  weeklyHours Int
  /// Structured breakdown: per-skill (and, for new categories, per-sub-skill)
  /// weekly minutes plus a short rationale. Shape documented in
  /// goal-plan.rules.ts rather than modeled as columns — it's LLM output,
  /// not something the application writes field-by-field.
  plan Json
  /// Tentative projected scores per exam, e.g.
  /// [{"label":"GRE","current":"310","projected":"320","note":"..."}].
  /// Always rendered with an "AI estimate" disclaimer — never persisted or
  /// displayed as a guarantee.
  tentativeScores Json?
  createdAt       DateTime @default(now())

  selectedForGoal Goal? @relation("SelectedPlan")
}
